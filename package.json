{
  "name": "schwepe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run rebuild-videos && vite",
    "dev:ssr": "NODE_ENV=development node server.js",
    "rebuild-videos": "node generate-media-list.js && cp saved_videos.json videos.json && sed -i 's/\"path\": \"public\\/saved_videos\\//\"path\": \"saved_videos\\//g' videos.json",
    "dev:full": "concurrently \"npm run cors-proxy\" \"npm run dev:ssr\"",
    "build": "node build-process.js build && node build-ssr.js",
    "preview": "vite preview",
    "preview:ssr": "NODE_ENV=production node server.js",
    "cors-proxy": "node cors-proxy-server.cjs",
    "preview:full": "concurrently \"npm run cors-proxy\" \"npm run preview:ssr\"",
    "start": "NODE_ENV=production node server.js",
    "start:dev": "NODE_ENV=development node server.js",
    "update-schwepes": "node scripts/update-schwepe-descriptions.cjs",
    "scan-schwepes": "node scripts/update-schwepe-descriptions.cjs --scan-only",
    "update-schwepes-zai": "ZAI_API_KEY=your_api_key_here node scripts/update-schwepe-descriptions.cjs",
    "deploy": "npm run build && git add . && git commit -m 'build: deployment build' && git push",
    "build:multi-site": "node build-multi-site.js",
    "build:all": "node build-multi-site.js && node build-process.js build",
    "test:gpu": "source /etc/profile.d/gpu-acceleration.sh && playwright test",
    "playwright:gpu": "source /etc/profile.d/gpu-acceleration.sh && playwright",
    "backup": "node scripts/coolify-backup.js",
    "backup:debug": "DEBUG=* node scripts/coolify-backup.js"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.0",
    "postcss": "^8.4.49",
    "vite": "^5.4.10",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.5.2",
    "tailwindcss": "^4.1.14"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.52.4",
    "@rollup/rollup-win32-x64-msvc": "^4.52.4"
  }
}