{
  "extends": ["google"],
  "parserOptions": {
    "ecmaVersion": 8
  },
  "env": {
    "es6": true,
    "node": true
  },
  "rules": {
    "max-len": ["error", {"code": 120}],
    "no-console": "off",
    "require-jsdoc": "off",
    "comma-dangle": "off",
    "object-curly-spacing": "off",
    "eol-last": "off"
  }
}